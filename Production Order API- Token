       '"Components": [' INTO lv_json.
      DATA(temp) = it_component[].
      SORT temp BY matnr.
      DESCRIBE TABLE temp LINES DATA(line).
      LOOP AT temp ASSIGNING FIELD-SYMBOL(<fx>).
        lv_qty = <fx>-bdmng.
        count = count + 1.
        CONCATENATE lv_json
           '{'
             '"Componentmaterial": "' <fx>-matnr'",'
             '"ComponentDescription": "' <fx>-maktx '",'
             '"Quantity": "' lv_qty'",'
             '"Uom": "' <fx>-meins '",'
             '"heatcode": ""'
             INTO lv_json.
        IF line = count.
          CONCATENATE lv_json '} ],' '"Operation": [' INTO lv_json.
        ELSE.
          CONCATENATE lv_json '},' INTO lv_json.
        ENDIF.
      ENDLOOP.
      DATA(temm) = it_operation[].
      DESCRIBE TABLE temm LINES DATA(cc).
      CLEAR count .
      LOOP AT temm ASSIGNING FIELD-SYMBOL(<lka>).
        count = count + 1.
        CONCATENATE lv_json
        '{'
          '"Activity": "' <lka>-vornr '",'
          '"ActivityDescription": "' <lka>-ltxa1 '",'
          '"WorkCenter": "' <lka>-steus '"'
